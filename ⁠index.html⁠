<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FitPulse Pro - Personal Gym Tracker</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        /* Nascondi la scrollbar per un look più nativo */
        ::-webkit-scrollbar { display: none; }
        body { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body class="bg-gray-950 text-gray-100 font-sans antialiased selection:bg-emerald-500 selection:text-black">

    <nav class="bg-gray-900/90 backdrop-blur-md border-b border-gray-800 sticky top-0 z-50">
        <div class="max-w-xl mx-auto px-4 py-3.5 flex justify-between items-center">
            <div class="flex items-center space-x-2">
                <div class="p-1.5 bg-emerald-500 rounded-lg text-black">
                    <i data-lucide="dumbbell" class="w-5 h-5 stroke-[2.5]"></i>
                </div>
                <span class="text-lg font-black tracking-wider text-white">FITPULSE <span class="text-emerald-400 text-xs font-bold px-1.5 py-0.5 bg-emerald-950 rounded border border-emerald-800/50">PRO</span></span>
            </div>
            <div class="flex space-x-1 bg-gray-950 p-1 rounded-xl border border-gray-800">
                <button onclick="switchTab('dashboard')" id="btn-dashboard" class="nav-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all duration-200 bg-emerald-500 text-black shadow-sm">Dashboard</button>
                <button onclick="switchTab('workout')" id="btn-workout" class="nav-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all duration-200 text-gray-400 hover:text-white">Scheda</button>
                <button onclick="switchTab('timer')" id="btn-timer" class="nav-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all duration-200 text-gray-400 hover:text-white">Timer</button>
            </div>
        </div>
    </nav>

    <main class="max-w-xl mx-auto px-4 py-6 pb-24">

        <section id="dashboard" class="tab-content space-y-6 animate-fade-in">
            <div class="bg-gradient-to-br from-emerald-600 via-teal-700 to-cyan-800 p-6 rounded-2xl shadow-xl relative overflow-hidden group">
                <div class="absolute -right-6 -bottom-6 opacity-10 text-white group-hover:scale-110 transition-transform duration-300">
                    <i data-lucide="dumbbell" class="w-32 h-32"></i>
                </div>
                <h1 class="text-2xl font-extrabold text-white mb-1">Pronto a spingere? ⚡</h1>
                <p class="text-emerald-100 text-sm leading-relaxed max-w-[85%]">La costanza batte il talento ogni singolo giorno. Completa i tuoi esercizi e aggiorna le tue statistiche.</p>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="bg-gray-900 p-4 rounded-xl border border-gray-800 flex flex-col justify-between">
                    <div class="flex justify-between items-start mb-2">
                        <span class="text-gray-400 text-xs font-medium uppercase tracking-wider">Allenamenti completi</span>
                        <div class="p-2 bg-emerald-500/10 rounded-lg text-emerald-400"><i data-lucide="trophy" class="w-4 h-4"></i></div>
                    </div>
                    <div>
                        <p id="stat-workouts" class="text-2xl font-black text-white">0</p>
                        <p class="text-xs text-gray-500 mt-0.5">Sessioni salvate</p>
                    </div>
                </div>
                <div class="bg-gray-900 p-4 rounded-xl border border-gray-800 flex flex-col justify-between">
                    <div class="flex justify-between items-start mb-2">
                        <span class="text-gray-400 text-xs font-medium uppercase tracking-wider">Esercizi Chiusi</span>
                        <div class="p-2 bg-blue-500/10 rounded-lg text-blue-400"><i data-lucide="check-circle" class="w-4 h-4"></i></div>
                    </div>
                    <div>
                        <p id="stat-exercises" class="text-2xl font-black text-white">0</p>
                        <p class="text-xs text-gray-500 mt-0.5">Target completati</p>
                    </div>
                </div>
            </div>

            <div class="bg-gray-900 p-5 rounded-xl border border-gray-800 space-y-3">
                <h3 class="text-sm font-bold text-gray-400 flex items-center gap-2 uppercase tracking-wide">
                    <i data-lucide="activity" class="text-emerald-400 w-4 h-4"></i> Stato Corrente
                </h3>
                <div class="p-3.5 bg-gray-950 rounded-lg border border-gray-800/60 flex justify-between items-center">
                    <div>
                        <p class="font-semibold text-sm text-white">Scheda di Allenamento Attiva</p>
                        <p id="dashboard-progress-text" class="text-xs text-gray-400 mt-0.5">Nessun esercizio completato oggi.</p>
                    </div>
                    <button onclick="switchTab('workout')" class="text-xs font-bold text-emerald-400 bg-emerald-500/10 px-3 py-1.5 rounded-lg hover:bg-emerald-500/20 transition">Apri</button>
                </div>
            </div>
        </section>

        <section id="workout" class="tab-content hidden space-y-6">
            <div class="flex justify-between items-center">
                <div>
                    <h2 class="text-xl font-black text-white tracking-tight">La tua Lista Esercizi</h2>
                    <p class="text-xs text-gray-400">Spunta gli esercizi man mano che li completi</p>
                </div>
                <button onclick="resetWorkout()" class="p-2 bg-gray-900 hover:bg-gray-800 text-amber-400 rounded-xl border border-gray-800 flex items-center gap-1.5 text-xs font-bold transition">
                    <i data-lucide="rotate-ccw" class="w-3.5 h-3.5"></i> Reset
                </button>
            </div>

            <div id="exercises-container" class="space-y-3">
                </div>

            <div class="bg-gray-900 p-5 rounded-xl border border-gray-800 space-y-4">
                <button onclick="toggleAddForm()" class="w-full flex justify-between items-center text-sm font-bold text-gray-300 focus:outline-none">
                    <span class="flex items-center gap-2"><i data-lucide="plus-circle" class="text-emerald-400 w-4 h-4"></i> Aggiungi Esercizio Personalizzato</span>
                    <i id="form-chevron" data-lucide="chevron-down" class="w-4 h-4 transition-transform"></i>
                </button>
                
                <div id="add-exercise-form" class="hidden space-y-3 pt-2 border-t border-gray-800/50">
                    <div>
                        <label class="block text-xs font-semibold text-gray-400 mb-1">Nome Esercizio</label>
                        <input type="text" id="new-name" placeholder="Es. Squat con Bilanciere" class="w-full bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm text-white focus:outline-none focus:border-emerald-500 font-medium">
                    </div>
                    <div class="grid grid-cols-3 gap-2">
                        <div>
                            <label class="block text-xs font-semibold text-gray-400 mb-1">Serie</label>
                            <input type="number" id="new-sets" placeholder="4" class="w-full bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm text-white focus:outline-none focus:border-emerald-500 font-medium">
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-gray-400 mb-1">Reps</label>
                            <input type="text" id="new-reps" placeholder="10" class="w-full bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm text-white focus:outline-none focus:border-emerald-500 font-medium">
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-gray-400 mb-1">Recupero (sec)</label>
                            <input type="number" id="new-rest" placeholder="90" class="w-full bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm text-white focus:outline-none focus:border-emerald-500 font-medium">
                        </div>
                    </div>
                    <button onclick="addCustomExercise()" class="w-full bg-emerald-500 hover:bg-emerald-600 text-black font-bold text-sm py-2.5 rounded-xl transition shadow-md shadow-emerald-500/10">Inserisci nella Scheda</button>
                </div>
            </div>

            <button onclick="completeSession()" class="w-full bg-gradient-to-r from-emerald-500 to-teal-600 text-black font-black text-sm py-3.5 rounded-xl transition shadow-lg shadow-emerald-500/20 active:scale-[0.99] flex items-center justify-center gap-2">
                <i data-lucide="check-square" class="w-4 h-4 stroke-[2.5]"></i> CONCLUDI E SALVA ALLENAMENTO
            </button>
        </section>

        <section id="timer" class="tab-content hidden flex flex-col items-center justify-center py-6 space-y-8">
            <div class="text-center">
                <h2 class="text-xl font-black text-white tracking-tight">Gestione Recuperi</h2>
                <p class="text-xs text-gray-400">Ottimizza i tempi di riposo tra le serie</p>
            </div>

            <div class="relative w-64 h-64 rounded-full border-4 border-gray-800 bg-gray-900 shadow-2xl flex flex-col items-center justify-center transition-all duration-300" id="timer-card">
                <div class="absolute inset-0 rounded-full border-4 border-emerald-500/30 animate-pulse" id="timer-glow"></div>
                <span id="timer-display" class="text-6xl font-mono font-black tracking-tighter text-white z-10">01:30</span>
                <span id="timer-status" class="text-xs font-bold text-emerald-400 mt-1 uppercase tracking-widest z-10">Pronto</span>
            </div>

            <div class="flex gap-2 w-full max-w-xs justify-center">
                <button onclick="setTimerPreset(60)" class="bg-gray-900 hover:bg-gray-800 border border-gray-800 text-xs font-bold px-3 py-1.5 rounded-lg transition text-gray-300">60s</button>
                <button onclick="setTimerPreset(90)" class="bg-gray-900 hover:bg-gray-800 border border-gray-800 text-xs font-bold px-3 py-1.5 rounded-lg transition text-gray-300">90s</button>
                <button onclick="setTimerPreset(120)" class="bg-gray-900 hover:bg-gray-800 border border-gray-800 text-xs font-bold px-3 py-1.5 rounded-lg transition text-gray-300">2min</button>
                <button onclick="setTimerPreset(180)" class="bg-gray-900 hover:bg-gray-800 border border-gray-800 text-xs font-bold px-3 py-1.5 rounded-lg transition text-gray-300">3min</button>
            </div>

            <div class="grid grid-cols-3 gap-3 w-full max-w-xs">
                <button onclick="startTimer()" class="bg-emerald-500 hover:bg-emerald-600 text-black font-extrabold py-3 rounded-xl transition shadow-md shadow-emerald-500/10 flex items-center justify-center gap-1 text-sm"><i data-lucide="play" class="w-4 h-4 fill-black"></i> Via</button>
                <button onclick="pauseTimer()" class="bg-amber-500 hover:bg-amber-600 text-black font-extrabold py-3 rounded-xl transition shadow-md shadow-amber-500/10 flex items-center justify-center gap-1 text-sm"><i data-lucide="pause" class="w-4 h-4 fill-black"></i> Pausa</button>
                <button onclick="resetTimer()" class="bg-gray-800 hover:bg-gray-700 text-white font-extrabold py-3 rounded-xl transition border border-gray-700 flex items-center justify-center gap-1 text-sm"><i data-lucide="refresh-cw" class="w-4 h-4"></i> Reset</button>
            </div>
        </section>

    </main>

    <script>
        const defaultExercises = [
            { id: 1, name: 'Panca Piana (Bilanciere)', sets: 4, reps: '8', rest: 120, done: false },
            { id: 2, name: 'Military Press', sets: 3, reps: '10', rest: 90, done: false },
            { id: 3, name: 'Dip alle Parallele', sets: 3, reps: 'Max', rest: 90, done: false },
            { id: 4, name: 'Alzate Laterali', sets: 3, reps: '12', rest: 60, done: false }
        ];

        let exercises = JSON.parse(localStorage.getItem('fp_exercises')) || defaultExercises;
        let stats = JSON.parse(localStorage.getItem('fp_stats')) || { workouts: 0, totalExercisesDone: 0 };

        let currentTimerDuration = 90;
        let timeLeft = currentTimerDuration;
        let timerId = null;

        window.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();
            renderExercises();
            updateStatsDisplay();
            updateTimerDisplay();
        });

        function switchTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(tab => tab.classList.add('hidden'));
            document.getElementById(tabId).classList.remove('hidden');

            document.querySelectorAll('.nav-btn').forEach(btn => {
                if(btn.id === `btn-${tabId}`) {
                    btn.className = "nav-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all duration-200 bg-emerald-500 text-black shadow-sm";
                } else {
                    btn.className = "nav-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all duration-200 text-gray-400 hover:text-white";
                }
            });
        }

        function renderExercises() {
            const container = document.getElementById('exercises-container');
            container.innerHTML = '';

            if(exercises.length === 0) {
                container.innerHTML = `<div class="text-center py-6 bg-gray-900 rounded-xl border border-gray-800 text-gray-500 text-xs">Nessun esercizio presente. Aggiungine uno sotto!</div>`;
                updateDashboardProgress();
                return;
            }

            exercises.forEach((ex) => {
                const card = document.createElement('div');
                card.className = `p-4 rounded-xl border transition-all duration-200 flex justify-between items-center ${ex.done ? 'bg-emerald-950/20 border-emerald-800/60 opacity-80' : 'bg-gray-900 border-gray-800'}`;
                
                card.innerHTML = `
                    <div class="flex-1 min-w-0 pr-4">
                        <h4 class="font-bold text-sm text-white truncate ${ex.done ? 'line-through text-gray-400' : ''}">${ex.name}</h4>
                        <div class="flex items-center gap-2 mt-1 text-xs text-gray-400 font-medium">
                            <span class="bg-gray-950 px-1.5 py-0.5 rounded text-gray-300">${ex.sets}x${ex.reps}</span>
                            <span class="flex items-center gap-0.5 text-gray-500"><i data-lucide="clock" class="w-3 h-3"></i> Rec: ${ex.rest}s</span>
                        </div>
                    </div>
                    <div class="flex items-center space-x-3">
                        <button onclick="startTimerFromExercise(${ex.rest})" class="p-2 bg-gray-950 text-emerald-400 rounded-lg hover:bg-gray-800 border border-gray-800/60 transition">
                            <i data-lucide="timer" class="w-4 h-4"></i>
                        </button>
                        <input type="checkbox" ${ex.done ? 'checked' : ''} onchange="toggleExercise(${ex.id})" class="w-5.5 h-5.5 rounded-lg border-gray-700 text-emerald-500 focus:ring-0 focus:ring-offset-0 bg-gray-950 accent-emerald-500 cursor-pointer">
                        <button onclick="deleteExercise(${ex.id})" class="p-1 text-gray-600 hover:text-rose-400 transition">
                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                        </button>
                    </div>
                `;
                container.appendChild(card);
            });

            lucide.createIcons();
            saveToStorage();
            updateDashboardProgress();
        }

        function toggleExercise(id) {
            const index = exercises.findIndex(e => e.id === id);
            if(index !== -1) {
                exercises[index].done = !exercises[index].done;
                renderExercises();
            }
        }

        function toggleAddForm() {
            const form = document.getElementById('add-exercise-form');
            const chevron = document.getElementById('form-chevron');
            form.classList.toggle('hidden');
            if(form.classList.contains('hidden')) {
                chevron.style.transform = 'rotate(0deg)';
            } else {
                chevron.style.transform = 'rotate(180deg)';
            }
        }

        function addCustomExercise() {
            const name = document.getElementById('new-name').value.trim();
            const sets = parseInt(document.getElementById('new-sets').value) || 3;
            const reps = document.getElementById('new-reps').value.trim() || '10';
            const rest = parseInt(document.getElementById('new-rest').value) || 90;

            if(!name) {
                alert("Inserisci almeno il nome dell'esercizio.");
                return;
            }

            const newEx = {
                id: Date.now(),
                name: name,
                sets: sets,
                reps: reps,
                rest: rest,
                done: false
            };

            exercises.push(newEx);
            renderExercises();

            document.getElementById('new-name').value = '';
            document.getElementById('new-sets').value = '';
            document.getElementById('new-reps').value = '';
            document.getElementById('new-rest').value = '';
            toggleAddForm();
        }

        function deleteExercise(id) {
            exercises = exercises.filter(e => e.id !== id);
            renderExercises();
        }

        function resetWorkout() {
            exercises.forEach(e => e.done = false);
            renderExercises();
        }

        function completeSession() {
            const doneCount = exercises.filter(e => e.done).length;
            if(doneCount === 0) {
                alert("Spunta almeno un esercizio completato prima di salvare!");
                return;
            }

            stats.workouts += 1;
            stats.totalExercisesDone += doneCount;
            
            localStorage.setItem('fp_stats', JSON.stringify(stats));
            updateStatsDisplay();
            
            alert("🔥 Allenamento completato con successo!");
            resetWorkout();
            switchTab('dashboard');
        }

        function updateStatsDisplay() {
            document.getElementById('stat-workouts').innerText = stats.workouts;
            document.getElementById('stat-exercises').innerText = stats.totalExercisesDone;
        }

        function updateDashboardProgress() {
            const text = document.getElementById('dashboard-progress-text');
            const total = exercises.length;
            const completed = exercises.filter(e => e.done).length;

            if(total === 0) {
                text.innerText = "Nessun esercizio caricato.";
            } else {
                text.innerText = `Completati: ${completed} di ${total} esercizi oggi.`;
            }
        }

        function saveToStorage() {
            localStorage.setItem('fp_exercises', JSON.stringify(exercises));
        }

        function updateTimerDisplay() {
            const minutes = Math.floor(timeLeft / 60);
            const seconds = timeLeft % 60;
            document.getElementById('timer-display').innerText = 
                `${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
        }

        function setTimerPreset(seconds) {
            pauseTimer();
            currentTimerDuration = seconds;
            timeLeft = seconds;
            updateTimerDisplay();
            document.getElementById('timer-status').innerText = "Impostato";
            document.getElementById('timer-card').className = "relative w-64 h-64 rounded-full border-4 border-gray-800 bg-gray-900 shadow-2xl flex flex-col items-center justify-center transition-all duration-300";
        }

        function startTimerFromExercise(seconds) {
            setTimerPreset(seconds);
            switchTab('timer');
            startTimer();
        }

        function startTimer() {
            if (timerId !== null) return;
            
            document.getElementById('timer-status').innerText = "Recupero...";
            document.getElementById('timer-card').classList.add('border-emerald-500');
            document.getElementById('timer-card').classList.remove('border-gray-800');

            timerId = setInterval(() => {
                if (timeLeft > 0) {
                    timeLeft--;
                    updateTimerDisplay();
                } else {
                    clearInterval(timerId);
                    timerId = null;
                    document.getElementById('timer-status').innerText = "Fatto! 💪";
                    document.getElementById('timer-card').className = "relative w-64 h-64 rounded-full border-4 border-amber-500 bg-gray-900 shadow-2xl flex flex-col items-center justify-center transition-all duration-300";
                    
                    if (navigator.vibrate) navigator.vibrate([200, 100, 200]);
                    alert("Tempo di recupero terminato!");
                    resetTimer();
                }
            }, 1000);
        }

        function pauseTimer() {
            clearInterval(timerId);
            timerId = null;
            document.getElementById('timer-status').innerText = "In Pausa";
            document.getElementById('timer-card').className = "relative w-64 h-64 rounded-full border-4 border-amber-500/50 bg-gray-900 shadow-2xl flex flex-col items-center justify-center transition-all duration-300";
        }

        function resetTimer() {
            clearInterval(timerId);
            timerId = null;
            timeLeft = currentTimerDuration;
            updateTimerDisplay();
            document.getElementById('timer-status').innerText = "Pronto";
            document.getElementById('timer-card').className = "relative w-64 h-64 rounded-full border-4 border-gray-800 bg-gray-900 shadow-2xl flex flex-col items-center justify-center transition-all duration-300";
        }
    </script>
</body>
</html>
